# Streamlit dashboard environment — copy to .env and fill in.

# Gateway base URL (optional; defaults to http://127.0.0.1:8000)
GATEWAY_URL=http://127.0.0.1:8000

# Bearer token for the gateway's /admin/* API.
# MUST match ADMIN_TOKEN in the gateway's own .env.
ADMIN_TOKEN=Please sign in from the main page before opening dashboard pages.
