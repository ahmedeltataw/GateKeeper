# ============================================================
# GateKeeper — environment template
# Copy to .env and fill in. You need ENCRYPTION_KEY + at least ONE provider key.
# All providers below are FREE and require NO payment card (verified June 2026).
# ============================================================

# --- Required: AES-256-GCM key for encrypting provider keys at rest ---
# Generate once with:
#   python -c "from cryptography.hazmat.primitives.ciphers.aead import AESGCM; import base64; print(base64.b64encode(AESGCM.generate_key(bit_length=256)).decode())"
ENCRYPTION_KEY=YOUR_32_BYTE_BASE64_KEY_HERE

# --- Server ---
PORT=8000
HOST=127.0.0.1
LOG_LEVEL=INFO
# Admin key guarding the dashboard + /admin API. Leave blank: on first run the
# dashboard mints a strong key in gk_... format and writes it back here for you.
ADMIN_TOKEN=
# DASHBOARD_PASSWORD=...     # optional; otherwise set on first dashboard login

# ============================================================
# Provider API keys — add at least one. (Keys auto-import to encrypted SQLite
# on first startup IF the DB has no keys yet; otherwise add via the dashboard.)
# Easiest no-card starters: GROQ, GEMINI, OPENROUTER, CLOUDFLARE.
# ============================================================

# Groq — FASTEST, instant signup, no card.  Key: https://console.groq.com/keys
# GROQ_KEY=gsk_...

# Google Gemini (AI Studio) — strong + vision + 1M ctx.  Key: https://aistudio.google.com/apikey
#   ⚠️ Free tier may use your prompts for training — don't send secrets.
# GEMINI_KEY=AIza...

# OpenRouter — dozens of :free models behind one key.  Key: https://openrouter.ai/settings/keys
# OPENROUTER_KEY=sk-or-v1-...

# Cloudflare Workers AI — 10k neurons/day, no training.  Token: https://dash.cloudflare.com/profile/api-tokens
#   Needs BOTH the account id and an API token with Workers AI read/edit.
# CLOUDFLARE_ACCOUNT_ID=...
# CLOUDFLARE_API_TOKEN=...

# Cerebras — fastest inference, huge daily budget (8K context cap).  Key: https://cloud.cerebras.ai
# CEREBRAS_KEY=csk-...

# NVIDIA NIM — large models (Llama 405B, DeepSeek R1).  Key: https://build.nvidia.com
# NVIDIA_KEY=nvapi-...

# Mistral — generous tokens (phone verify; trains on data by default).  Key: https://console.mistral.ai
# MISTRAL_KEY=...

# GitHub Models — only no-card source of GPT-4o/4.1 (tight limits).
#   Fine-grained PAT with "models:read": https://github.com/settings/personal-access-tokens
# GITHUB_KEY=github_pat_...

# Z.ai (GLM) — strong coding, permanently-free Flash models.  Key: https://z.ai/manage-apikey/apikey-list
# ZAI_API_KEY=...

# HuggingFace — eval only (~$0.10/month free credit).  Token: https://huggingface.co/settings/tokens/new
# HF_KEY=hf_...
